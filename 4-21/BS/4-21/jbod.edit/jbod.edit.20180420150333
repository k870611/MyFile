	`id` INT(11) NOT NULL AUTO_INCREMENT,
	`server_type` VARCHAR(10) DEFAULT '',
	`command` VARCHAR(MAX) DEFAULT '',
	`alias` VARCHAR(20) DEFAULT '',
	`freq` INT(11) DEFAULT 0,
)
 
CREATE PROCEDURE query_task_list()
BEGIN

    SELECT A.server_id `server_id`, A.ip `ip`, B.task_command, B.freq
	  FROM `server_list` A, `task_list` B
     WHERE A.server_type = B.server_type
END

CREATE PROCEDURE insert_server_type(server_type VARCHAR(10))
BEGIN

	UPDATE server_list 
	   SET server_type=@server_type
	 WHERE server_id = @server_id
	   AND server_type<>@server_type

EDN

